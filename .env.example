# Superset Configuration
SUPERSET_AI_SUPERSET_BASE_URL=http://localhost:8088
SUPERSET_AI_SUPERSET_USERNAME=admin
SUPERSET_AI_SUPERSET_PASSWORD=admin

# LLM Provider: 'copilot' (default) or 'openai'
SUPERSET_AI_LLM_PROVIDER=copilot

# GitHub Copilot Configuration (used when LLM_PROVIDER=copilot)
# No API key needed - uses 'gh auth token' automatically
SUPERSET_AI_COPILOT_MODEL=gpt-4o

# OpenAI Configuration (only needed when LLM_PROVIDER=openai)
# SUPERSET_AI_OPENAI_API_KEY=sk-your-openai-api-key
# SUPERSET_AI_OPENAI_MODEL=gpt-4o

# Optional Settings
SUPERSET_AI_REQUEST_TIMEOUT=30
SUPERSET_AI_MAX_RETRIES=3
SUPERSET_AI_LOG_LEVEL=INFO
