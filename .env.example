# Superset Configuration
SUPERSETAI_SUPERSET_BASE_URL=http://localhost:8088
SUPERSETAI_SUPERSET_USERNAME=admin
SUPERSETAI_SUPERSET_PASSWORD=admin

# LLM Provider: 'copilot' (default) or 'openai'
SUPERSETAI_LLM_PROVIDER=copilot

# GitHub Copilot Configuration (used when LLM_PROVIDER=copilot)
# No API key needed - uses 'gh auth token' automatically
SUPERSETAI_COPILOT_MODEL=gpt-4o

# OpenAI Configuration (only needed when LLM_PROVIDER=openai)
# SUPERSETAI_OPENAI_API_KEY=sk-your-openai-api-key
# SUPERSETAI_OPENAI_MODEL=gpt-4o

# Optional Settings
SUPERSETAI_REQUEST_TIMEOUT=30
SUPERSETAI_MAX_RETRIES=3
SUPERSETAI_LOG_LEVEL=INFO
